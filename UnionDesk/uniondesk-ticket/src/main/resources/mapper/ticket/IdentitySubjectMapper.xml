<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.uniondesk.ticket.mapper.IdentitySubjectMapper">

    <resultMap id="IdentitySubjectPo" type="com.uniondesk.ticket.entity.IdentitySubjectPo">
        <id property="id" column="id"/>
        <result property="subjectType" column="subject_type"/>
        <result property="phone" column="phone"/>
        <result property="status" column="status"/>
    </resultMap>

    <select id="findById" resultMap="IdentitySubjectPo">
        SELECT id, subject_type, phone, status
        FROM identity_subject
        WHERE id = #{id}
        LIMIT 1
    </select>

    <select id="findIdByPhone" resultType="java.lang.Long">
        SELECT id
        FROM identity_subject
        WHERE phone = #{phone}
        LIMIT 1
    </select>

    <insert id="insert" parameterType="com.uniondesk.ticket.entity.IdentitySubjectPo">
        INSERT INTO identity_subject (id, subject_type, phone, status)
        VALUES (#{id}, #{subjectType}, #{phone}, #{status})
    </insert>

</mapper>
