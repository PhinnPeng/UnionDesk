<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.uniondesk.ticket.mapper.CustomerAccountMapper">

    <select id="findSubjectIdById" resultType="java.lang.Long">
        SELECT subject_id
        FROM customer_account
        WHERE id = #{id}
        LIMIT 1
    </select>

</mapper>
